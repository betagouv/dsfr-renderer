{
	"name": "@gouvfr/dsfr-render",
	"version": "0.0.1",
	"description": "json-render integration for DSFR — Generate AI-powered French government interfaces with type-safe components",
	"keywords": [
		"dsfr",
		"json-render",
		"react",
		"ai",
		"generative-ui",
		"french-government",
		"design-system",
		"france",
		"rgaa",
		"accessibility"
	],
	"author": "BetaGouv",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/betagouv/dsfr-renderer.git"
	},
	"bugs": {
		"url": "https://github.com/betagouv/dsfr-renderer/issues"
	},
	"homepage": "https://github.com/betagouv/dsfr-renderer#readme",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./core": {
			"import": "./dist/core/index.js",
			"types": "./dist/core/index.d.ts"
		},
		"./react": {
			"import": "./dist/react/index.js",
			"types": "./dist/react/index.d.ts"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "turbo run build && bun build ./src/index.ts --outdir ./dist --target node --sourcemap --external @json-render/core --external @json-render/react --external @gouvfr/dsfr --external react --external react-dom --external zod",
		"dev": "turbo run dev",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "rm -rf dist && turbo run clean",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"workspaces": ["packages/*"],
	"dependencies": {
		"@json-render/core": "^0.16.0",
		"@json-render/react": "^0.14.0",
		"dsfr-renderer-core": "workspace:*",
		"dsfr-renderer-react": "workspace:*",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/react": "^19.0.0",
		"react": "^19.0.0",
		"turbo": "^2.7.0",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"@gouvfr/dsfr": ">=1.14.0",
		"react": ">=18.0.0",
		"zod": ">=4.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "bun@1.2.0"
}
